# =========================================================
# CPSC 250 / CPSC 250L Standard .gitignore
# Python + PyCharm + LaTeX + macOS
# =========================================================

# ---------------------------------------------------------
# Python bytecode
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ---------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------
# PyCharm / JetBrains
# ---------------------------------------------------------
.idea/
*.iml

# ---------------------------------------------------------
# VS Code
# ---------------------------------------------------------
.vscode/

# ---------------------------------------------------------
# macOS
# ---------------------------------------------------------
.DS_Store

# ---------------------------------------------------------
# Windows
# ---------------------------------------------------------
Thumbs.db
desktop.ini

# ---------------------------------------------------------
# Jupyter notebooks
# ---------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------
# Python testing / coverage
# ---------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# ---------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------
build/
dist/
*.egg-info/

# ---------------------------------------------------------
# Logs / temporary files
# ---------------------------------------------------------
*.tmp
*.temp
*.log

# ---------------------------------------------------------
# Local environment files
# ---------------------------------------------------------
.env

# ---------------------------------------------------------
# mypy / linting
# ---------------------------------------------------------
.mypy_cache/
.ruff_cache/

# =========================================================
# LaTeX build artifacts
# =========================================================

# Core LaTeX
*.aux
*.out
*.toc
*.lof
*.lot

# latexmk
*.fdb_latexmk
*.fls

# SyncTeX
*.synctex.gz

# Bibliography
*.bbl
*.bcf
*.blg
*.run.xml

# Beamer/navigation
*.nav
*.snm

# Index/glossary
*.idx
*.ilg
*.ind
*.glo
*.gls

# Misc
*.xdv

# ---------------------------------------------------------
# Generated PDFs
#
# Uncomment ONLY if you do NOT want PDFs tracked.
# ---------------------------------------------------------
# *.pdf

# ---------------------------------------------------------
# Generated images
#
# Uncomment if desired.
# ---------------------------------------------------------
# *.png
# *.jpg
